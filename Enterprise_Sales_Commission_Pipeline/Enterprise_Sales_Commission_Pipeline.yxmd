<?xml version="1.0" encoding="utf-8"?>
<AlteryxDocument yxmdVer="2024.1">

  <!-- ═══════════════════════════════════════════════════════════════════
       WORKFLOW: Enterprise Sales & Commission Pipeline
       Author  : Sales Analytics Team
       Version : 3.0   |   Last Updated: 2024-06-30
       
       FLOW SUMMARY
       ════════════
       [1] INPUT LAYER
           ├─ sales_transactions.csv  → 60 transaction rows
           ├─ customers.csv           → 20 customer records
           ├─ products.csv            → 10 product records
           ├─ sales_reps.csv          → 5 rep records
           └─ regional_targets.csv    → 8 target rows

       [2] DATA QUALITY & STANDARDISATION
           ├─ Filter: remove returned transactions  (T/F split)
           ├─ Formula: parse Quarter from TransactionDate
           └─ Select: drop raw columns no longer needed

       [3] JOIN LAYER  (star-schema enrichment)
           ├─ Join 1: Transactions ← Customers  (CustomerID)
           ├─ Join 2: +Products               (ProductID)
           ├─ Join 3: +Sales Reps             (SalesRepID)
           └─ Join 4: +Regional Targets       (Region + Quarter)

       [4] FORMULA ENRICHMENT
           ├─ NetRevenue  = Qty × UnitPrice × (1 − Discount)
           ├─ Margin      = (NetRevenue − CostPrice×Qty) / NetRevenue
           ├─ DealTier    = Platinum / Gold / Silver / Bronze
           ├─ DaysToClose = DATEDIFF from AccountOpenDate
           └─ vs_Target   = NetRevenue / (RevenueTarget / 90)

       [5] MACRO: CommissionCalculator.yxmc
           └─ FinalCommission, CommissionBand per transaction

       [6] AGGREGATION LAYER
           ├─ Summarize A: Customer-level KPIs
           ├─ Summarize B: Product-level KPIs
           ├─ Summarize C: Rep-level performance
           └─ Summarize D: Region × Quarter dashboard

       [7] OUTPUT LAYER
           ├─ Output 1: customer_kpi_report.csv
           ├─ Output 2: product_performance.csv
           ├─ Output 3: rep_commission_report.csv
           └─ Output 4: regional_dashboard.csv
       ═══════════════════════════════════════════════════════════════════ -->

  <Nodes>

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║       LAYER 1: INPUTS           ║ -->
    <!-- ╚══════════════════════════════════╝ -->

    <!-- Tool 1: Input – Sales Transactions -->
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <Passwords/>
          <File RecordLimit="" SearchSubDirs="False" FileFormat="0">.\data\sales_transactions.csv</File>
          <FormatSpecificOptions>
            <FirstRowData>False</FirstRowData>
            <IgnoreErrors>False</IgnoreErrors>
            <AllowShareWrite>False</AllowShareWrite>
            <HeaderRow>True</HeaderRow>
            <IgnoreQuotes>False</IgnoreQuotes>
            <Delimeter>,</Delimeter>
            <CodePage>28591</CodePage>
            <MaxFieldLen>254</MaxFieldLen>
            <Optimize>True</Optimize>
            <FullPath>True</FullPath>
            <SignedData>False</SignedData>
          </FormatSpecificOptions>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Sales Transactions (60 rows)</Name>
          <DefaultAnnotationText>60 raw transaction records Jan–Jun 2024&#xA;Includes returns, discounts, payment methods</DefaultAnnotationText>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePlugins.dll" EngineDllEntryPoint="AlteryxDbFileInput"/>
    </Node>

    <!-- Tool 2: Input – Customers -->
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="162"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File RecordLimit="" SearchSubDirs="False" FileFormat="0">.\data\customers.csv</File>
          <FormatSpecificOptions>
            <HeaderRow>True</HeaderRow>
            <Delimeter>,</Delimeter>
          </FormatSpecificOptions>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Customers Dimension (20 rows)</Name>
          <DefaultAnnotationText>Customer master: segment, region, credit limit</DefaultAnnotationText>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePlugins.dll" EngineDllEntryPoint="AlteryxDbFileInput"/>
    </Node>

    <!-- Tool 3: Input – Products -->
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="270"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File RecordLimit="" SearchSubDirs="False" FileFormat="0">.\data\products.csv</File>
          <FormatSpecificOptions>
            <HeaderRow>True</HeaderRow>
