    <MetaInfo>
      <n>Enterprise_Sales_Commission_Pipeline</n>
      <description>Complex multi-input sales and commission analytics workflow.
5 inputs (60 transactions + 4 dimension tables).
Star-schema joins, formula enrichment, commission macro, 4-stream aggregation.
Outputs: Customer KPIs, Product Performance, Rep Commission, Regional Dashboard, Returns log.
      </description>
      <author>Sales Analytics Team</author>
      <version>3.0</version>
      <lastSavedAlteryxVersion>2024.1.0</lastSavedAlteryxVersion>
    </MetaInfo>
