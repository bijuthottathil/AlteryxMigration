    <!-- Tool 5: Input – Regional Targets -->
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="486"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File RecordLimit="" SearchSubDirs="False" FileFormat="0">.\data\regional_targets.csv</File>
          <FormatSpecificOptions>
            <HeaderRow>True</HeaderRow>
            <Delimeter>,</Delimeter>
          </FormatSpecificOptions>
