  <Connections>
    <!-- Input → Filter -->
    <Connection><Origin ToolID="1" Connection="Output"/><Destination ToolID="10" Connection="Input"/></Connection>
    <!-- Filter FALSE → returned_orders output -->
    <Connection><Origin ToolID="10" Connection="False"/><Destination ToolID="64" Connection="Input"/></Connection>
    <!-- Filter TRUE → Formula date parse -->
    <Connection><Origin ToolID="10" Connection="True"/><Destination ToolID="11" Connection="Input"/></Connection>
    <!-- Formula → Select clean -->
    <Connection><Origin ToolID="11" Connection="Output"/><Destination ToolID="12" Connection="Input"/></Connection>

    <!-- Join 1: Transactions (L) + Customers (R) -->
    <Connection><Origin ToolID="12" Connection="Output"/><Destination ToolID="20" Connection="Left"/></Connection>
    <Connection><Origin ToolID="2"  Connection="Output"/><Destination ToolID="20" Connection="Right"/></Connection>
    <!-- Join 2: +Products -->
    <Connection><Origin ToolID="20" Connection="Join"/><Destination ToolID="21" Connection="Left"/></Connection>
    <Connection><Origin ToolID="3"  Connection="Output"/><Destination ToolID="21" Connection="Right"/></Connection>
    <!-- Join 3: +Reps -->
    <Connection><Origin ToolID="21" Connection="Join"/><Destination ToolID="22" Connection="Left"/></Connection>
    <Connection><Origin ToolID="4"  Connection="Output"/><Destination ToolID="22" Connection="Right"/></Connection>
    <!-- Join 4: +Regional Targets -->
    <Connection><Origin ToolID="22" Connection="Join"/><Destination ToolID="23" Connection="Left"/></Connection>
    <Connection><Origin ToolID="5"  Connection="Output"/><Destination ToolID="23" Connection="Right"/></Connection>

    <!-- Formula KPI enrichment -->
    <Connection><Origin ToolID="23" Connection="Join"/><Destination ToolID="30" Connection="Input"/></Connection>

    <!-- Add ReturnFlag for macro -->
    <Connection><Origin ToolID="30" Connection="Output"/><Destination ToolID="41" Connection="Input"/></Connection>
    <!-- Macro: Commission Calculator -->
    <Connection><Origin ToolID="41" Connection="Output"/><Destination ToolID="40" Connection="Input"/></Connection>

    <!-- Fan-out to all 4 Summarize nodes -->
    <Connection><Origin ToolID="40" Connection="Output"/><Destination ToolID="50" Connection="Input"/></Connection>
    <Connection><Origin ToolID="40" Connection="Output"/><Destination ToolID="52" Connection="Input"/></Connection>
    <Connection><Origin ToolID="40" Connection="Output"/><Destination ToolID="53" Connection="Input"/></Connection>
    <Connection><Origin ToolID="40" Connection="Output"/><Destination ToolID="55" Connection="Input"/></Connection>

    <!-- Post-agg formulas -->
    <Connection><Origin ToolID="50" Connection="Output"/><Destination ToolID="51" Connection="Input"/></Connection>
    <Connection><Origin ToolID="53" Connection="Output"/><Destination ToolID="54" Connection="Input"/></Connection>
    <Connection><Origin ToolID="55" Connection="Output"/><Destination ToolID="56" Connection="Input"/></Connection>

    <!-- Outputs -->
