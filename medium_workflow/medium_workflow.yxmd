<AlteryxDocument>
  <Nodes>
    <Node ToolID="1"><GuiSettings Plugin="AlteryxBasePluginsGui.InputData"/>
      <Properties><Configuration><File>customers.csv</File></Configuration></Properties></Node>
    <Node ToolID="2"><GuiSettings Plugin="AlteryxBasePluginsGui.InputData"/>
      <Properties><Configuration><File>orders.csv</File></Configuration></Properties></Node>
    <Node ToolID="3"><GuiSettings Plugin="AlteryxBasePluginsGui.Join"/></Node>
    <Node ToolID="4"><GuiSettings Plugin="AlteryxBasePluginsGui.Filter"/>
      <Properties><Configuration><Expression>[amount] > 100</Expression></Configuration></Properties></Node>
    <Node ToolID="5"><GuiSettings Plugin="AlteryxBasePluginsGui.Summarize"/>
      <Properties><Configuration><GroupBy>country</GroupBy><Sum>amount</Sum></Configuration></Properties></Node>
  </Nodes>
  <Connections>
    <Connection Source="1" Destination="3"/>
    <Connection Source="2" Destination="3"/>
    <Connection Source="3" Destination="4"/>
    <Connection Source="4" Destination="5"/>
  </Connections>
</AlteryxDocument>